# Streamlit Cloud secrets template.
#
# DO NOT commit a real ``secrets.toml`` to the repo — that file is in
# .gitignore. Instead, paste the contents below (with real values
# filled in) into the **Secrets** field on Streamlit Cloud:
#
#     1. Open https://share.streamlit.io
#     2. Pick this app
#     3. Settings -> Secrets -> paste the TOML below -> Save
#
# Streamlit Cloud surfaces these to the running app as
# ``st.secrets["KEY"]`` and also as ``os.environ["KEY"]`` (which is
# what the bot's connectors and the chatbot's LLM clients read), so
# this template is all that's required — no code changes needed.
#
# All three keys are optional individually:
#   * Without ANTHROPIC_API_KEY the chatbot falls back to GitHub
#     Models (free) using GITHUB_TOKEN, then to Gemini.
#   * Without GITHUB_TOKEN you lose the free-tier Models endpoint
#     and the chatbot will only work if Anthropic or Gemini is set.
#   * Without GEMINI_API_KEY only the Gemini provider is unavailable;
#     the rest of the bot is unaffected.

# ---------------------------------------------------------------------
# LLM provider keys (used by the chatbot tool dispatcher and the daily
# predictions / news-sentiment pipelines).
#
# Aliases — the codebase reads either name for these two keys, but
# Streamlit Cloud only forwards what you put here. Pick one of each
# pair. The canonical names (left column) are recommended.
#
#   GITHUB_TOKEN     ←→ GH_TOKEN
#   GEMINI_API_KEY   ←→ GOOGLE_API_KEY
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY  = "sk-ant-api03-..."
GITHUB_TOKEN       = "ghp_..."
GEMINI_API_KEY     = "AIza..."
